{
  "manifest_version": "0.3",
  "name": "passwd",
  "display_name": "passwd.team",
  "description": "Team vault access — browse secrets, get TOTP codes, run commands with injected credentials, and connect to services directly using credentials from the vault.",
  "version": "1.6.0",
  "author": { "name": "passwd.team", "url": "https://passwd.team" },
  "server": {
    "type": "node",
    "entry_point": "dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/dist/index.js"],
      "env": {
        "PASSWD_ORIGIN": "${user_config.passwd_origin}"
      }
    }
  },
  "tools_generated": true,
  "user_config": {
    "passwd_origin": {
      "type": "string",
      "title": "Deployment URL",
      "description": "Your passwd.team deployment URL (e.g. https://app.passwd.team)",
      "default": "https://app.passwd.team"
    }
  },
  "compatibility": {
    "platforms": ["darwin"],
    "runtimes": { "node": ">=18.0.0" }
  }
}
